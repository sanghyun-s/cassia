# =============================================================
# CoReckoner — .gitignore
# =============================================================
# Keeps secrets, environment cruft, and runtime data out of git.
# Source code, docs, and schemas go in. Everything else stays out.

# ── Secrets ────────────────────────────────────────────────
# CRITICAL: the .env file contains OPENAI_API_KEY. Never commit it.
.env
.env.*
!.env.example
*.pem
*.key
secrets.json

# ── Python ─────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/

# ── OS / editor cruft ──────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Icon?
.AppleDouble
.LSOverride
._*

# Editors
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.spyderproject
.spyproject

# Jupyter
.ipynb_checkpoints/
*.ipynb

# ── Runtime data (DBs, vector stores, uploads) ─────────────
# These get regenerated by sql/phase1_load.py and rag/phase1_ingest.py.
# We DO commit /data (source files) and /docs.
outputs/*.db
outputs/*.db-shm
outputs/*.db-wal
outputs/sessions/
outputs/chroma_db/
outputs/temp/

# Backup folders
*.bak/
*.bak.zip
app2_backup_*/
app2_backup_*.zip

# ── Logs ───────────────────────────────────────────────────
*.log
logs/
term_log_*

# ── macOS Finder ───────────────────────────────────────────
.fseventsd/
.Spotlight-V100
.Trashes

# ── Misc temp ──────────────────────────────────────────────
*.tmp
*.temp
*.pid
*.seed

# Phase 5 close-out — exclude all runtime outputs from git tracking
outputs/
*.bak
__pycache__/
*.pyc
.DS_Store
venv/
.env
outputs/coreckoner.db
outputs/sessions/
outputs/chroma_db/

# local patch backups + caches (2026-06-09)
*.bak
__pycache__/
*.pyc
.DS_Store
