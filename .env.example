# =============================================================
# CoReckoner — Environment Variables
# =============================================================
# Copy this file to `.env` and fill in your actual values.
# `.env` is gitignored — never commit your real API key.

# Required: OpenAI API key for GPT-4o-mini (SQL generation + RAG synthesis)
OPENAI_API_KEY=sk-your-key-here

# Optional: override the default port (default 8002)
# PORT=8002
